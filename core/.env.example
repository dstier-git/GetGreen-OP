# Copy to .env in this directory (core/) and fill in. Do not commit .env.
# Backend (core/backend/Response) loads via load_dotenv() when run from project root or core.

# Required for Supabase (used if configured)
# SUPABASE_URL=https://....
# SUPABASE_KEY=...

# Optional: frontend API base URL (default: http://localhost:8000)
# VITE_API_BASE_URL=http://localhost:8000

# Optional: OpenAI API key (only needed if using ChatGPT provider)
# OPENAI_API_KEY=sk-...
# OPEN_AI_KEY=sk-...  # legacy env var supported

# Optional: override OpenAI model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
